{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "deepshape-marketplace",
  "version": "1.0.0",
  "tags": ["DEEPSHAPE", "分享", "公开"],
  "description": "DEEPSHAPE AI技能库",
